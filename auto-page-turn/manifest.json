{
  "manifest_version": 3,
  "name": "Auto Scroll - 自动翻页",
  "version": "1.0.0",
  "description": "自动平滑滚动网页，支持双向滚动、速度调节和键盘快捷键控制。",

  "permissions": ["activeTab", "storage"],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "自动翻页"
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "auto-scroll@autoscroller"
    }
  }
}
