{
  "manifest_version": 3,
  "name": "Auto Scroll",
  "version": "1.0.0",
  "description": "Smooth auto-scrolling for mobile browsers. Tap the indicator to start/stop.",

  "permissions": ["storage", "activeTab"],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Auto Scroll"
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "auto-scroll-android@autoscroller"
    }
  }
}
