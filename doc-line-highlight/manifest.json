{
  "manifest_version": 3,
  "name": "Doc Line Highlight - 文档逐行高亮",
  "version": "1.0.0",
  "description": "Ctrl+↓/↑ 逐行高亮跳转，支持网页 Markdown、PDF.js 渲染的 PDF、在线文档阅读场景。",

  "permissions": ["activeTab", "storage"],

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "文档逐行高亮"
  },

  "commands": {
    "next-line": {
      "suggested_key": { "default": "Ctrl+Down", "mac": "MacCtrl+Down" },
      "description": "高亮下一行"
    },
    "prev-line": {
      "suggested_key": { "default": "Ctrl+Up", "mac": "MacCtrl+Up" },
      "description": "高亮上一行"
    },
    "toggle-highlight": {
      "suggested_key": { "default": "Ctrl+Shift+L", "mac": "MacCtrl+Shift+L" },
      "description": "开启/关闭逐行高亮模式"
    }
  },

  "background": {
    "service_worker": "background/background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/style.css"],
      "run_at": "document_idle"
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "doc-line-highlight@highlighter"
    }
  }
}
