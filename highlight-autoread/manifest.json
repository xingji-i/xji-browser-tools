{
  "manifest_version": 3,
  "name": "Highlight AutoRead - 高亮跟读",
  "version": "1.0.0",
  "description": "高亮定位 + 自动翻页：逐行高亮阅读，页面自动跟随滚动，支持速度调节和键盘快捷键。",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "高亮跟读"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "toggle-autoread": {
      "suggested_key": {
        "default": "Ctrl+Space",
        "mac": "MacCtrl+Space"
      },
      "description": "开始/暂停自动跟读"
    },
    "next-line": {
      "suggested_key": {
        "default": "Ctrl+Down",
        "mac": "MacCtrl+Down"
      },
      "description": "高亮下一行"
    },
    "prev-line": {
      "suggested_key": {
        "default": "Ctrl+Up",
        "mac": "MacCtrl+Up"
      },
      "description": "高亮上一行"
    },
    "toggle-highlight": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "MacCtrl+Shift+L"
      },
      "description": "开关高亮模式（不自动滚动）"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/style.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "highlight-autoread@autoscroller"
    }
  }
}
